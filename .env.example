# =============================================================================
# CONFIGURAÇÕES DE AMBIENTE - SAPIENS PLATAFORMA ACADÊMICA
# =============================================================================
# Copie este arquivo para .env e ajuste os valores conforme necessário

# -----------------------------------------------------------------------------
# CONFIGURAÇÕES GERAIS
# -----------------------------------------------------------------------------
SAPIENS_ENV=desenvolvimento
SAPIENS_DEBUG=true
SAPIENS_LOG_LEVEL=INFO

# -----------------------------------------------------------------------------
# CONFIGURAÇÕES DE MODELOS DE IA
# -----------------------------------------------------------------------------
# OpenRouter API (obrigatório para funcionamento dos agentes LLM)
# Obtenha sua chave em: https://openrouter.ai/keys
OPENAI_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_API_BASE=https://openrouter.ai/api/v1

# Modelo LLM — lido pelo CrewAI para TODOS os agentes (fallback se llm_config.yaml falhar)
# O modelo ativo é gerenciado via src/Sapiens_MultiAgente/config/llm_config.yaml
# e pode ser alterado em runtime via POST /api/config/llm sem reiniciar o servidor.
#
# Sufixo :free = tier gratuito do OpenRouter (sem custo por token)
# Opções recomendadas:
#   openrouter/meta-llama/llama-3.3-8b-instruct:free  (gratuito, rápido)
#   openrouter/meta-llama/llama-3.1-70b-instruct:free (gratuito, maior qualidade)
#   openrouter/google/gemma-4-31b-it:free              (gratuito, Gemma 4 - 31B denso)
#   openrouter/google/gemma-4-26b-a4b-it:free          (gratuito, Gemma 4 - 26B MoE)
#   openrouter/mistralai/mistral-7b-instruct:free      (gratuito, eficiente)
#   openrouter/auto                                     (melhor disponível, pode ter custo)
MODEL=openrouter/meta-llama/llama-3.3-8b-instruct:free
SAPIENS_DEFAULT_MODEL=openrouter/meta-llama/llama-3.3-8b-instruct:free
SAPIENS_TEMPERATURE=0.7

# Timeout máximo por execução completa da crew (segundos). Padrão: 7200 (2h)
SAPIENS_CREW_TIMEOUT=7200

# -----------------------------------------------------------------------------
# CONFIGURAÇÕES DE SEGURANÇA
# -----------------------------------------------------------------------------
# Senha do usuário admin padrão (altere antes de usar em produção!)
SAPIENS_ADMIN_PASSWORD=sua-senha-segura-aqui

# Caminho do banco de dados SQLite
SAPIENS_DB_PATH=sapiens.db

# Tamanho máximo de arquivos (em MB)
SAPIENS_MAX_FILE_SIZE=100

# Habilitar validação de dados pessoais (PII)
SAPIENS_ENABLE_PII_DETECTION=true

# Habilitar auditoria detalhada
SAPIENS_ENABLE_DETAILED_AUDIT=true

# -----------------------------------------------------------------------------
# CONFIGURAÇÕES WEB
# -----------------------------------------------------------------------------
# Interface web
FLASK_APP=src/Sapiens_MultiAgente/web/app.py
FLASK_ENV=desenvolvimento
FLASK_DEBUG=true

# Secret key para sessões Flask (IMPORTANTE: altere para produção)
FLASK_SECRET_KEY=sua-secret-key-muito-segura-aqui

# Host e porta do servidor web
WEB_HOST=127.0.0.1
WEB_PORT=5000

# -----------------------------------------------------------------------------
# CONFIGURAÇÕES DE ARQUIVOS
# -----------------------------------------------------------------------------
# Diretório para uploads
UPLOAD_FOLDER=uploads

# Diretório para logs
LOGS_FOLDER=logs

# Diretório para dados temporários
TEMP_FOLDER=temp

# -----------------------------------------------------------------------------
# CONFIGURAÇÕES DE AUDITORIA
# -----------------------------------------------------------------------------
# Retenção de logs (em dias)
AUDIT_RETENTION_DAYS=90

# Formato de logs (json, csv, txt)
AUDIT_FORMAT=json

# -----------------------------------------------------------------------------
# CONFIGURAÇÕES DE PERFORMANCE
# -----------------------------------------------------------------------------
# Número máximo de análises simultâneas
MAX_CONCURRENT_ANALYSES=3

# Timeout por análise (em minutos)
ANALYSIS_TIMEOUT_MINUTES=30

# Habilitar cache de resultados
ENABLE_CACHE=true

# -----------------------------------------------------------------------------
# CONFIGURAÇÕES DE DESENVOLVIMENTO (apenas para ambiente dev)
# -----------------------------------------------------------------------------
# Recarregar automaticamente no desenvolvimento
FLASK_AUTO_RELOAD=true

# Mostrar SQL queries (debug)
LOG_SQL_QUERIES=false

# Salvar requests/responses para debug
SAVE_REQUESTS_RESPONSES=true

# -----------------------------------------------------------------------------
# CONFIGURAÇÕES DE PRODUÇÃO (ajuste conforme necessário)
# -----------------------------------------------------------------------------
# Para produção, defina:
# SAPIENS_ENV=producao
# SAPIENS_DEBUG=false
# FLASK_DEBUG=false
# FLASK_AUTO_RELOAD=false
# LOG_SQL_QUERIES=false
# SAVE_REQUESTS_RESPONSES=false
# SAPIENS_LOG_LEVEL=WARNING

# -----------------------------------------------------------------------------
# EXEMPLOS DE CONFIGURAÇÕES PARA DIFERENTES AMBIENTES
# -----------------------------------------------------------------------------

# Desenvolvimento (já configurado acima)
# SAPIENS_ENV=desenvolvimento

# Homologação
# SAPIENS_ENV=homologacao
# SAPIENS_LOG_LEVEL=INFO
# SAPIENS_DEBUG=false

# Produção
# SAPIENS_ENV=producao
# SAPIENS_LOG_LEVEL=WARNING
# SAPIENS_DEBUG=false
# FLASK_DEBUG=false

# -----------------------------------------------------------------------------
# DICAS DE SEGURANÇA
# -----------------------------------------------------------------------------
# 1. Nunca commite arquivos .env com dados reais para o repositório
# 2. Use variáveis de ambiente em produção
# 3. Configure firewall apropriado
# 4. Use HTTPS em produção
# 5. Monitore logs regularmente
# 6. Faça backup dos dados importantes